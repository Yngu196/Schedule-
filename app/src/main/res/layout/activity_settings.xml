<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 背景图片 -->
    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_flower_pattern"
        android:contentDescription="背景" />

    <!-- 磨砂玻璃遮罩 -->
    <View
        android:id="@+id/glass_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 应用设置标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="应用设置"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginBottom="24dp" />

            <!-- 学期与周次设置卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_transparent"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="学期与周次"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="16dp" />

                <!-- 当前学期 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="当前学期"
                        android:textSize="16sp"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/tv_current_semester"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2024-2025学年 第一学期"
                        android:textSize="14sp"
                        android:textColor="#4A90E2"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/btn_modify_semester"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="修改"
                        android:textSize="14sp"
                        android:textColor="#4A90E2"
                        android:padding="8dp"
                        android:background="?attr/selectableItemBackground" />

                </LinearLayout>

                <!-- 默认显示周 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="默认显示周"
                        android:textSize="16sp"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/tv_default_week"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="第1周"
                        android:textSize="14sp"
                        android:textColor="#4A90E2"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/btn_modify_week"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="设置"
                        android:textSize="14sp"
                        android:textColor="#4A90E2"
                        android:padding="8dp"
                        android:background="?attr/selectableItemBackground" />

                </LinearLayout>

            </LinearLayout>

            <!-- 课表外观设置卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_transparent"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="课表外观"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="16dp" />

                <!-- 背景设置 -->
                <TextView
                    android:id="@+id/btn_background_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="背景设置"
                    android:textSize="15sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="start|center_vertical" />

                <!-- 外观设置（透明度等） -->
                <TextView
                    android:id="@+id/btn_appearance_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="卡片外观设置"
                    android:textSize="15sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="start|center_vertical" />

            </LinearLayout>

            <!-- 时间表设置卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_transparent"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="时间表设置"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/btn_time_table_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="编辑时间表"
                    android:textSize="15sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="start|center_vertical" />

            </LinearLayout>

            <!-- 提醒设置卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_transparent"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="提醒设置"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="16dp" />

                <!-- 课前提醒 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="课前提醒"
                        android:textSize="16sp"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/tv_default_alarm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="提前15分钟"
                        android:textSize="14sp"
                        android:textColor="#4A90E2"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/btn_modify_alarm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="设置"
                        android:textSize="14sp"
                        android:textColor="#4A90E2"
                        android:padding="8dp"
                        android:background="?attr/selectableItemBackground" />

                </LinearLayout>

                <!-- 提醒开关 -->
                <TextView
                    android:id="@+id/btn_alarm_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="课前提醒开关"
                    android:textSize="15sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="start|center_vertical"
                    android:layout_marginBottom="8dp" />

                <!-- 权限检查 -->
                <TextView
                    android:id="@+id/btn_permission_guide"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="权限设置引导"
                    android:textSize="15sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="start|center_vertical" />

            </LinearLayout>

            <!-- 数据管理卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_transparent"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="数据管理"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="16dp" />

                <!-- 从教务系统导入 -->
                <TextView
                    android:id="@+id/btn_school_import"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="从教务系统导入"
                    android:textSize="15sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center" />

                <!-- 导入课程表 -->
                <TextView
                    android:id="@+id/btn_import_schedule"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="从文件导入"
                    android:textSize="15sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="start|center_vertical" />

                <!-- 导出课程表 -->
                <TextView
                    android:id="@+id/btn_export_schedule"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="导出课程表"
                    android:textSize="15sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="start|center_vertical" />

                <!-- 清除所有数据 -->
                <TextView
                    android:id="@+id/btn_clear_data"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="清除所有数据"
                    android:textSize="15sp"
                    android:textColor="#FF6B6B"
                    android:padding="12dp"
                    android:background="@drawable/bg_button_outline_red"
                    android:gravity="start|center_vertical" />

            </LinearLayout>

            <!-- 免责声明卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_transparent"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="免责声明"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. 本应用所有课程数据均由用户自行导入或手动添加\n2. 教务系统导入功能仅供学习研究使用\n3. 所有数据均存储在本地设备上\n4. 使用本应用产生的风险由用户自行承担\n5. 应用UI设计参考了WakeUp课程表官方设计\n6. 本项目基于wakeup3.612版本进行魔改重构，遵循相同的开源原则"
                    android:textSize="12sp"
                    android:textColor="#CCFFFFFF"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- 关于与更新卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_transparent"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="关于与更新"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/btn_check_update"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="检测更新"
                    android:textSize="15sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/btn_about"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="关于应用"
                    android:textSize="15sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="start|center_vertical" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>
