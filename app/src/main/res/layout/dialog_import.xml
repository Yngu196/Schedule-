<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="导入课程"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- 说明文字 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="已支持从上千所学校的教务直接导入课程\n也可以去申请适配试试看:)"
        android:textColor="#666666"
        android:textSize="12sp" />

    <!-- 导入选项列表 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/btn_import_school"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="从学校教务导入"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:background="?attr/selectableItemBackground" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <TextView
            android:id="@+id/btn_import_excel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="从 Excel 导入"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:background="?attr/selectableItemBackground" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <TextView
            android:id="@+id/btn_import_file"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="从分享/导出文件导入"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:background="?attr/selectableItemBackground" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <TextView
            android:id="@+id/btn_apply_adapter"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="申请适配"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</LinearLayout>
