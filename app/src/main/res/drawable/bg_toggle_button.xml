<?xml version="1.1" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外层光晕 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1A7C4DFF" />
        </shape>
    </item>
    <!-- 白色边框 -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <stroke
                android:width="1.5dp"
                android:color="#40FFFFFF" />
            <solid android:color="#407C4DFF" />
        </shape>
    </item>
    <!-- 内层高光 -->
    <item
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp">
        <shape android:shape="oval">
            <solid android:color="#507C4DFF" />
        </shape>
    </item>
</layer-list>
